   348                           global clear_ram
   349                           ;	Called with FSR containing the base address, and
   350                           ;	W with the last address+1
   351  0005                     clear_ram:
   352  0005  0064               	clrwdt			;clear the watchdog before getting into this loop
   353  0006                     clrloop:
   354  0006  0180               	clrf	indf		;clear RAM location pointed to by FSR
   355  0007  0A84               	incf	fsr,f		;increment pointer
   356  0008  0604               	xorwf	fsr,w		;XOR with final address
   357  0009  1903               	btfsc	status,2	;have we reached the end yet?
   358  000A  3400               	retlw	0		;all done for this memory range, return
   359  000B  0604               	xorwf	fsr,w		;XOR again to restore value
   360  000C  2806               	goto	clrloop		;do the next byte
