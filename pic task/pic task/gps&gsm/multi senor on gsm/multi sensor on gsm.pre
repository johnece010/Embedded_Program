void delay(unsigned int a)
{
while(a--);
}

void lcd_cmd(unsigned char com)
{
PORTD=(com&0xf0);
RD1=0;
RD2=0;
RD3=1;
delay(200);
RD3=0;
temp=com<<4;
PORTD=(temp&0xf0);
RD1=0;
RD2=0;
RD3=1;
delay(200);
RD3=0;
}
void lcd_data(unsigned char dat)
{
PORTD=(dat&0xf0);
RD1=1;
RD2=0;
RD3=1;
delay(200);
RD3=0;
temp=dat<<4;
PORTD=(temp&0xf0);
RD1=1;
RD2=0;
RD3=1;
delay(200);
RD3=0;
}
void lcd_display(const unsigned char *m)
{
for(int k=0;m[k]!=0;k++)
{
lcd_data(m[k]);
}
}
void lcd_init()
{
lcd_cmd(0x02);
lcd_cmd(0x2c);
lcd_cmd(0x06);
lcd_cmd(0x01);
lcd_cmd(0x0c);
lcd_cmd(0x80);
}


void gsm_command(const unsigned char *da)
{
unsigned int s;
for(s=0;da[s]!=0;s++)
{
while(!TXIF)
{
}
OERR=0;
TXREG=da[s];
}
}

void txs(unsigned char val)
{
while(!TXIF)
{
}
OERR=0;
TXREG=val;
}

void sms1()
{
txs('A');txs('T');txs('+');txs('C');txs('M');txs('G');
txs('S');txs('=');
txs('"');
txs('8');txs('0');txs('9');txs('8');txs('1');
txs('4');txs('2');txs('0');txs('6');txs('4');
txs('"');
txs(13); delay(10000);txs(10);

delay(600);
delay(600);

gsm_command("sensor abnormal");
delay(5000);
TXREG=0x0D;

delay(5000);
TXREG=(a+0x30);
delay(100);
TXREG=(c+0x30);
delay(100);
TXREG=(e+0x30);
delay(100);
TXREG=(f+0x30);
delay(100);

TXREG=0x0D;

delay(5000);
TXREG=(a1+0x30);
delay(100);
TXREG=(c1+0x30);
delay(100);
TXREG=(e1+0x30);
delay(100);
TXREG=(f1+0x30);
delay(100);


TXREG=0x0D;

delay(5000);
TXREG=(a2+0x30);
delay(100);
TXREG=(c2+0x30);
delay(100);
TXREG=(e2+0x30);
delay(100);
TXREG=(f2+0x30);
delay(100);


TXREG=0x0D;

delay(5000);
TXREG=(a3+0x30);
delay(100);
TXREG=(c3+0x30);
delay(100);
TXREG=(e3+0x30);
delay(100);
TXREG=(f3+0x30);
delay(100);

delay(600);
txs(13);delay(60000);
txs(10);
delay(10000);

txs(26);
delay(50000);delay(50000);
delay(50000);delay(50000);
}

void serial(const unsigned char *a)
{
unsigned char i;
for(i=0;a[i]!=0;i++)
{
TXREG=a[i];
delay(20000);

}
}

void main()
{
ADCON1=0X80;
ADCON0=0X40;

TRISD=0x00;
PORTD=0x00;

TRISA=0x0F;
PORTA=0x00;

TRISC=0x00;
PORTC=0x00;

TRISB=0X03;
PORTB=0X00;

lcd_init();
delay(100);

TXSTA=0x24;
RCSTA=0x90;
SPBRG=25;

delay(600);
PEIE=1;
GIE=1;

delay(600);
lcd_cmd(0x80);

lcd_display("WELCOME");
delay(50000);delay(50000);
lcd_cmd(0x01);
while(1)
{
CHS2=0;
CHS1=0;
CHS0=0;
ADON=1;
delay(600);
ADCON0=(ADCON0|0X04);
delay(600);
temp1=ADRESH<<8;
delay(600);
temp1=temp1+ADRESL;
delay(600);
delay(600);
a=temp1/1000;
b=temp1%1000;
c=b/100;
d=b%100;
e=d/10;
f=d%10;

lcd_cmd(0x80);
lcd_data(a+0x30);
delay(5000);
lcd_data(c+0x30);
delay(5000);
lcd_data(e+0x30);
delay(5000);
lcd_data(f+0x30);
delay(5000);


CHS2=0;
