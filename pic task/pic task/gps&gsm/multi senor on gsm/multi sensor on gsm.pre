delay(5000);
lcd_data(e3+0x30);
delay(5000);
lcd_data(f3+0x30);
delay(5000);

if((temp1>=500)||(temp2>=500)||(temp3>=500)||(temp4>=500))
{
lcd_cmd(0x01);
lcd_cmd(0x80);
lcd_display("sensor abnormal");
delay(50000);
serial("AT");
txs(13);delay(60000);delay(60000);
txs(10);
delay(10000);
delay(10000);
serial("AT+CMGF=1");
txs(13);delay(60000);
delay(60000);
txs(10);
delay(10000);
delay(10000);

sms1();

}


