   403                           global clear_ram
   404                           ;	Called with FSR containing the base address, and
   405                           ;	W with the last address+1
   406  0052                     clear_ram:
   407  0052  0064               	clrwdt			;clear the watchdog before getting into this loop
   408  0053                     clrloop:
   409  0053  0180               	clrf	indf		;clear RAM location pointed to by FSR
   410  0054  0A84               	incf	fsr,f		;increment pointer
   411  0055  0604               	xorwf	fsr,w		;XOR with final address
   412  0056  1903               	btfsc	status,2	;have we reached the end yet?
   413  0057  3400               	retlw	0		;all done for this memory range, return
   414  0058  0604               	xorwf	fsr,w		;XOR again to restore value
   415  0059  2853               	goto	clrloop		;do the next byte
   416                           
